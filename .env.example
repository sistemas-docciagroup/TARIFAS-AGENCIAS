# --- SAP R3 SOAP integration ---
SAP_ENABLED=false
SAP_ENDPOINT=http://SRVPRD.MAMPA.local:8000/sap/bc/srt/rfc/sap/z_claude_code_02/700/z_claude_code_02/z_claude_code_02_bin?sap-client=700&sap-language=ES
SAP_CALL_DELAY_MS=200

# --- Motor IA (OpenAI / ChatGPT) ---
# Sin esta clave la app ARRANCA igual: clasificador y generador usan un modo
# "offline" de demostración. Pon la clave cuando quieras IA real.
OPENAI_API_KEY=

# Modelos (puedes cambiarlos sin tocar codigo). Motor por defecto: GPT-5.5.
OPENAI_MODEL_CLASIFICADOR=gpt-5.5
OPENAI_MODEL_GENERADOR=gpt-5.5

# --- Zendesk (opcional al principio; el store mock trae tickets de ejemplo) ---
ZENDESK_SUBDOMAIN=
ZENDESK_EMAIL=
ZENDESK_API_TOKEN=
ZENDESK_WEBHOOK_SECRET=

# --- Servidor ---
PORT=3000

# --- Umbrales de seguridad ---
UMBRAL_CONFIANZA=0.6
UMBRAL_ENFADO=0.7
